# ─────────────────────────────────────────────────────────────────────────────
# .env.example — шаблон переменных окружения
# Скопируй в .env.local и заполни значения. Не коммить реальный .env.local!
# ─────────────────────────────────────────────────────────────────────────────

# URL сайта (без слэша в конце)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin-панель: логин и пароль
ADMIN_USER=admin
# Рекомендуется хешированный пароль — сгенерируй: node scripts/gen-password-hash.mjs
ADMIN_PASSWORD_HASH=<saltHex>:<derivedKeyHex>
# Или для быстрого старта (небезопасно для прода):
# ADMIN_PASSWORD=changeme

# PostgreSQL
DATABASE_URL=postgresql://mustercore:changeme@localhost:5432/mustercore
POSTGRES_PASSWORD=changeme

# Email-уведомления через Resend (https://resend.com)
# Если не задан — письма не отправляются, заявки всё равно сохраняются в БД
RESEND_API_KEY=
RESEND_FROM=MusterCore <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# Отключает телеметрию Next.js
NEXT_TELEMETRY_DISABLED=1
